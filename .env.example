# 세션 쿠키 서명용 비밀 키
# `openssl rand -base64 48`로 생성
AUTH_SECRET=replace-with-a-long-random-secret

# Kakao Developers > 앱 > 플랫폼 키 > REST API 키
KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key

# 로컬 개발용 콜백 주소
# Vercel 배포 후에는 https://배포도메인/api/auth/kakao/callback 로 변경 필요
KAKAO_REDIRECT_URI=http://localhost:3001/api/auth/kakao/callback

# 카카오 콘솔에서 클라이언트 시크릿을 ON으로 둔 경우에만 입력
KAKAO_CLIENT_SECRET=

# 카카오 동의항목을 콘솔에서 켠 뒤에만 추가
# 예: profile_nickname,profile_image
KAKAO_SCOPES=
